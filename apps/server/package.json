{
  "name": "@students-talk/server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/main.js",
    "prisma": "prisma",
    "db:generate": "prisma generate --schema=../../prisma/schema.prisma",
    "db:push": "prisma db push --schema=../../prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=../../prisma/schema.prisma"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/platform-socket.io": "^10.3.0",
    "@nestjs/websockets": "^10.3.0",
    "@students-talk/prompts": "workspace:*",
    "@students-talk/types": "workspace:*",
    "axios": "^1.14.0",
    "dotenv": "^16.4.0",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "socket.io": "^4.6.1",
    "uuid": "^9.0.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@prisma/client": "^5.10.0",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.5.10",
    "prisma": "^5.10.0",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.8",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
